# ============================================================
# SKILLBRIDGE BD — Environment Variables (ALL FREE TIER)
# Copy this to .env.local and fill in all values
# ============================================================

# --- SUPABASE (FREE — https://supabase.com)
# Free plan: 500MB DB, 50MB storage, 2GB bandwidth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- GROQ AI (FREE — https://console.groq.com)
# Free plan: 30 req/min, 6000 req/day — more than enough to start
# Models used: llama-3.3-70b-versatile, llama-3.1-8b-instant
# Sign up at: https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_your_groq_key_here

# --- RESEND EMAIL (FREE — https://resend.com)
# Free plan: 3000 emails/month — plenty for early stage
# Sign up at: https://resend.com → API Keys → Create
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=noreply@yourdomain.com
# NOTE: Without a domain, use: EMAIL_FROM=onboarding@resend.dev (Resend test domain)

# --- JWT Secret (generate free: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-here

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SkillBridge BD

# --- bKash Sandbox (FREE — https://developer.bka.sh)
# Register free developer account for sandbox testing
# Production requires business registration
BKASH_APP_KEY=your_bkash_sandbox_app_key
BKASH_APP_SECRET=your_bkash_sandbox_app_secret
BKASH_USERNAME=your_bkash_sandbox_username
BKASH_PASSWORD=your_bkash_sandbox_password
NEXT_PUBLIC_BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

# --- Nagad Sandbox (FREE — https://nagad.com.bd/developer)
NAGAD_MERCHANT_ID=your_nagad_sandbox_merchant_id
NAGAD_MERCHANT_KEY=your_nagad_sandbox_merchant_key
NEXT_PUBLIC_NAGAD_BASE_URL=http://sandbox.mynagad.com:10080/remote-payment-gateway-1.0

# ============================================================
# TOTAL COST TO RUN THIS APP = ৳0 (FREE)
# Supabase Free + Groq Free + Resend Free + Vercel Free
# ============================================================
